# Google AdSense Environment Variables
# Copy this file to .env.local and fill in your actual values
# Do NOT commit .env.local to your repo

# Your AdSense Publisher ID (from AdSense dashboard, e.g. ca-pub-1234567890123456)
VITE_ADSENSE_CLIENT_ID=ca-pub-YOUR_PUBLISHER_ID

# Ad Slot ID for the top banner (horizontal leaderboard)
VITE_ADSENSE_TOP_SLOT=1234567890

# Ad Slot ID for the bottom banner (horizontal leaderboard)
VITE_ADSENSE_BOTTOM_SLOT=0987654321
